# Copy this file to .env.local and fill in your values
# .env.local is gitignored and should NEVER be committed
#
# Sourced by scripts/run-daily.sh; read by the translation pipeline.

# ── Translation backend ───────────────────────────────────────────────────────
# Priority (decided in scripts/translate/claude.js):
#   DEEPSEEK_API_KEY set  → DeepSeek (api.deepseek.com, OpenAI-compatible)  ← 推荐
#   USE_CLAUDE_CLI=true    → local `claude` CLI (whatever ~/.claude points to)
#   ANTHROPIC_API_KEY set  → Anthropic SDK direct

# DeepSeek — get a key at https://platform.deepseek.com (API keys page)
DEEPSEEK_API_KEY=

# Optional overrides (defaults shown)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Fallback backend (only used if DEEPSEEK_API_KEY is empty)
ANTHROPIC_API_KEY=
